<?xml version="1.0"?>
<!--
  Phase 1 MVP: Gazebo world only, no UAV spawn.
  Loads MAP1.world from fuae_gazebo by default and exposes Gazebo ROS interface.
-->
<launch>
  <arg name="world_name" default="MAP1"/>
  <arg name="world_file" default="$(find fuae_gazebo)/worlds/$(arg world_name).world"/>
  <arg name="gui"        default="true"/>
  <arg name="paused"     default="false"/>
  <arg name="debug"      default="false"/>
  <arg name="verbose"    default="true"/>

  <env name="GAZEBO_MODEL_PATH"
       value="$(optenv GAZEBO_MODEL_PATH):$(find rotors_gazebo)/models:$(find fuae_gazebo)"/>
  <env name="GAZEBO_RESOURCE_PATH"
       value="$(optenv GAZEBO_RESOURCE_PATH):$(find rotors_gazebo)/models:$(find fuae_gazebo)"/>
  <!-- Make librealsense_gazebo_plugin.so (built in star-searcher devel) discoverable. -->
  <env name="GAZEBO_PLUGIN_PATH"
       value="$(optenv GAZEBO_PLUGIN_PATH):$(env HOME)/star-searcher/devel/lib"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_file)"/>
    <arg name="gui"        value="$(arg gui)"/>
    <arg name="paused"     value="$(arg paused)"/>
    <arg name="debug"      value="$(arg debug)"/>
    <arg name="verbose"    value="$(arg verbose)"/>
    <arg name="use_sim_time" value="true"/>
  </include>
</launch>
